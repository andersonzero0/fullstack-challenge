{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:prune": "docker compose down -v --rmi all --remove-orphans && docker volume prune -f",
    "test:unit:games": "cd services/games && bun test tests/unit",
    "test:unit:wallets": "cd services/wallets && bun test tests/unit",
    "test:e2e:games": "cd services/games && bun test tests/e2e",
    "test:e2e:frontend": "cd frontend && npx playwright test",
    "test": "bun run test:unit:games && bun run test:unit:wallets && bun run test:e2e:games && bun run test:e2e:frontend"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
